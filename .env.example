# Full path to bun — needed so Xcode's restricted PATH can find it (dev-ios)
BUN=/opt/homebrew/bin/bun

# Default iOS simulator for dev-ios (override on the CLI: just dev-ios "iPhone 15 Pro")
IOS_SIMULATOR="iPhone 17"

# Android SDK and NDK paths (dev-android)
ANDROID_HOME=~/Library/Android/sdk
NDK_HOME=~/Library/Android/sdk/ndk/30.0.14904198
